# Distributed Sharding System - Environment Configuration
# Configure the IP addresses and ports for each shard node
# Update these values based on your network setup

# Gateway Configuration
GATEWAY_PORT=8000

# Shard Node 1 (change to IP if running on another laptop)
SHARD1_HOST=localhost
SHARD1_PORT=8001

# Shard Node 2 (change to IP if running on another laptop)
SHARD2_HOST=localhost
SHARD2_PORT=8002

# Shard Node 3 (change to IP if running on another laptop)
SHARD3_HOST=localhost
SHARD3_PORT=8003

# Shard Node 4 (change to IP if running on another laptop)
SHARD4_HOST=10.12.70.74
SHARD4_PORT=8004

# ============================================================
# INSTRUCTIONS:
# ============================================================
# 1. Find the IP address of each laptop running a shard:
#    - macOS: ipconfig getifaddr en0
#    - Linux: hostname -I | awk '{print $1}'
#    - Windows: ipconfig | findstr IPv4
#
# 2. Update the SHARDX_HOST value with the laptop's IP
#
# 3. Restart the gateway to apply changes:
#    ./bin/gateway
#
# ============================================================
# EXAMPLE: All 4 shards on different laptops
# ============================================================
# SHARD1_HOST=192.168.1.101
# SHARD1_PORT=8001
# SHARD2_HOST=192.168.1.102
# SHARD2_PORT=8002
# SHARD3_HOST=192.168.1.103
# SHARD3_PORT=8003
# SHARD4_HOST=192.168.1.104
# SHARD4_PORT=8004
